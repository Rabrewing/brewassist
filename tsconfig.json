{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    },
    "types": ["node", "react", "react-dom", "jest"],
    "incremental": true
  },
  "include": [
    "next-env.d.ts",
    "pages/**/*",
    "components/**/*",
    "lib/**/*",
    "contexts/**/*",
    "styles/**/*",
    "scripts/**/*",
    "overlays/**/*",
    "task_complete.ts",
    "__tests__/**/*"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "sandbox",
    "brewdocs/tests",
    // other BrewVerse projects – keep TS out of these
    "brewlotto",
    "brewsearch",
    "brewpulse",
    "brewgold",
    "brewgold-backup",
    "brewexec-platform",
    "project-zahav",
    "brewpulse-insight"
  ]
}
