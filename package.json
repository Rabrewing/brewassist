{
  "name": "brewassist",
  "version": "1.0.0",
  "type": "module",
  "dependencies": {
    "body-parser": "^2.2.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "framer-motion": "^12.23.24",
    "highlight.js": "^11.11.1",
    "http-proxy-middleware": "^3.0.5",
    "jest-fetch-mock": "^3.0.3",
    "next": "^16.0.1",
    "openai": "^6.9.1",
    "playwright-core": "^1.53.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^9.0.0",
    "remark-gfm": "^4.0.1"
  },
  "scripts": {
    "dev": "BREWTRUTH_ENABLED=true next dev -p 3000",
    "dev:comment": "NOTE: BREWTRUTH_ENABLED is set here as a temporary workaround because .env.local variables are not reliably picked up by the Next.js dev server in this specific setup. This ensures BrewTruth is active during development. For production, environment variables should be managed by the deployment platform.",
    "build": "next build",
    "start": "next start -p 3000",
    "test": "jest",
    "test:ui": "jest __tests__/ui/ tests/ui/",
    "test:chain": "jest __tests__/brewassist.chain.gates.test.ts",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "lint": "eslint pages components lib contexts --ext .ts,.tsx,.js,.jsx",
    "format": "prettier --write .",
    "lint:staged": "lint-staged",
    "s4:lock-check": "pnpm lint && pnpm typecheck && pnpm test && pnpm test:ui && tsx scripts/audit-capabilities.ts && pnpm build",
    "s4:gate": "./scripts/s4-lock-gate.sh",
    "s4:manifest:verify": "tsx scripts/s4-manifest-verify.ts",
    "s4:manifest:update": "tsx scripts/s4-manifest-verify.ts --update",
    "s5:brewdocs:verify": "./scripts/s5-brewdocs-verify.sh",
    "s5:support:verify": "./scripts/s5-support-verify.sh",
    "audit:capabilities": "tsx scripts/audit-capabilities.ts",
    "sandbox:mirror": "tsx scripts/sandbox_build_mirror.ts",
    "smoke:sandbox": "curl -sS -X POST http://localhost:3000/api/sandbox -H \"Content-Type: application/json\" -d '{\"engine\":\"tiny\",\"prompt\":\"smoke\"}' | cat"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "DevOps-first AI cockpit for the BrewVerse. BrewAssist is a safety-gated engineering assistant that can analyze, patch, and maintain code using BrewTruth, BrewLast, sandbox tools, and multi-engine LLM routing.",
  "devDependencies": {
    "@eslint/compat": "^2.0.0",
    "@eslint/js": "^9.39.1",
    "@next/eslint-plugin-next": "^16.0.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "24.10.1",
    "@types/react": "19.2.3",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.46.4",
    "@typescript-eslint/parser": "^8.46.4",
    "autoprefixer": "^10.4.22",
    "dotenv": "^17.2.3",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "lint-staged": "^16.2.6",
    "node-mocks-http": "^1.17.2",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.1.17",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.6",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.46.4",
    "whatwg-fetch": "^3.6.20"
  }
}
