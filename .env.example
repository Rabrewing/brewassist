###############################################################
#  BREWASSIST .env.local — FULL SYSTEM CONFIGURATION (S4.8d+)
#  THIS FILE MUST NOT BE COMMITTED TO GIT
###############################################################

# =============================================================
# ===============  OPENAI ENGINE CONFIGURATION ================
# =============================================================

OPENAI_API_KEY=

# Core models for router
OPENAI_MODEL_MINI=gpt-4.1-mini        # fast / everyday
OPENAI_MODEL_DEEP=gpt-4.1             # deep reasoning / HRM

# Optional legacy aliases (keep for now if code references them)
OPENAI_MODEL_PRIMARY=${OPENAI_MODEL_MINI}
OPENAI_MODEL_SECONDARY=${OPENAI_MODEL_DEEP}
OPENAI_MODEL_FAST=${OPENAI_MODEL_MINI}

# Older single-ID (if some legacy code still uses this)
OPENAI_MODEL_ID=${OPENAI_MODEL_MINI}

# Base URL (default OpenAI)
OPENAI_BASE_URL=https://api.openai.com/v1

# Personality tuning (S4.4 – optional, used by identity layer)
OPENAI_PERSONALITY_TIER=gold
OPENAI_PERSONALITY_SHIMMER=soft
OPENAI_PERSONALITY_SAFETY=high

# =============================================================
# ===============  GOOGLE TTS / SPEECH CONFIG  ================
# =============================================================

GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_TTS_VOICE=en-US-Standard-F
GOOGLE_TTS_LANGUAGE=en-US
GOOGLE_TTS_SPEED=1.0
GOOGLE_TTS_PITCH=0.0

# =============================================================
# ==================  NIM RESEARCH ENGINE  ====================
# =============================================================

# === NIMs / NVIDIA Researcher — S4.8f ===
 
# Turn NIMs research mode on/off without code changes
NIMS_ENABLED=true
 
# Core credentials
NIMS_API_KEY=nvapi-...your_real_key...
NIMS_BASE_URL=https://integrate.api.nvidia.com/v1
 
# Preferred + fallback models (you can tweak based on what your key can access)
NIMS_MODEL_PREFERRED=nemotron-3-8b-instruct
NIMS_MODEL_FALLBACK_1=llama-3.1-8b-instruct
NIMS_MODEL_FALLBACK_2=mistral-7b-instruct   # optional, only if exposed via NVIDIA for your key
 
# Tuning knobs (optional but nice to have)
NIMS_MAX_TOKENS=1536
NIMS_TEMPERATURE=0.2
NIMS_MODE=research          # “analysis”, “research”, etc – for your own tagging
NIMS_RESEARCH_DEPTH=standard # “standard” | “deep” | “fast”
NIMS_TIMEOUT_MS=20000

# Provider ID for router
NIMS_PROVIDER_ID=nims 
 

# =============================================================
# =================  GEMINI LAYER (PRIMARY/ALT) ===============
# =============================================================

GEMINI_API_KEY=

# Router-friendly names
GEMINI_MODEL_FLASH=gemini-2.0-flash
GEMINI_MODEL_DEEP=gemini-2.0-pro

# Legacy aliases (keep for now)
GEMINI_MODEL_PRIMARY=${GEMINI_MODEL_FLASH}
GEMINI_MODEL_SECONDARY=${GEMINI_MODEL_DEEP}

# Optional mode hint
GEMINI_MODE=fallback

# Optional custom base URL if you ever proxy Gemini
# GEMINI_BASE_URL=http://localhost:8080

# =============================================================
# ====================  MISTRAL ENGINE  =======================
# =============================================================

MISTRAL_ENABLED=true

# Official Mistral HTTP endpoint (OpenAI-compatible)
MISTRAL_BASE_URL=https://api.mistral.ai/v1

# API key from console.mistral.ai
MISTRAL_API_KEY=sk-mistral-xxxxxxxxxxxxxxxxxx

# Primary / secondary models
MISTRAL_MODEL_PRIMARY=mistral-small-latest
MISTRAL_MODEL_SECONDARY=mistral-large-latest

# Optional routing hints (used by model-router)
MISTRAL_ROLE_LLM=true
MISTRAL_ROLE_AGENT=false


# Local GGUF paths (dev-only, for llama.cpp or similar)
MISTRAL_LOCAL_PATH=./models/mistral-7b-instruct=v0.2.Q3_K_M.gguf
TINYLLAMA_LOCAL_PATH=./models/tinyllama-1.1b.gguf

# =============================================================
# ================  BREWASSIST CORE SETTINGS  =================
# =============================================================

BREWASSIST_ENV=production
BREWASSIST_IDENTITY_TIER=gold
BREWASSIST_MODE=devops
BREWASSIST_GATEKEEPER=enabled
BREWASSIST_ROUTING=intent
NEXT_PUBLIC_BREWASSIST_HOST=http://localhost:3000
BREWASSIST_REPO_ROOT=/home/brewexec/brewassist

BREWASSIST_HELP_GUIDE_PATH=./brewdocs/BrewAssist_Help_Guide.md

BREWASSIST_ALLOW_NON_DEVOPS=false
BREWASSIST_DEVOPS_ONLY=true

# =============================================================
# ===================  PRIMARY & LOCAL MODELS =================
# =============================================================

# High-level “what BrewAssist thinks it’s using”
BREWASSIST_PRIMARY_MODEL=${OPENAI_MODEL_MINI}
BREWASSIST_FALLBACK_MODEL=${GEMINI_MODEL_FLASH}
BREWASSIST_LOCAL_MODEL=tinyllama

# =============================================================
# ====== MULTI-ENGINE ROUTER FLAGS (OPENAI / NIM / GEMINI) ====
# =============================================================

BREWASSIST_ROUTER_OPENAI=enabled
BREWASSIST_ROUTER_NIM=enabled
BREWASSIST_ROUTER_GEMINI=enabled

# =============================================================
# ============  BREWTRUTH (Governance Policy Layer) ===========
# =============================================================

BREWTRUTH_MODE=strict
BREWTRUTH_EXPECTED_TIER=identity
BREWTRUTH_POLICY_VERSION=4.1
BREWTRUTH_ENFORCE_INTENT=true
BREWTRUTH_EMOTION_GUARD=enabled
BREWTRUTH_LOGGING=full

# =============================================================
# =================  BREWLAST STATE ENGINE  ===================
# =============================================================

BREWLAST_PATH=./brewassist_state/.brewlast.json
BREWLAST_HISTORY_LIMIT=40
BREWLAST_FLUSH_ON_ERROR=true

# =============================================================
# ==============  BREWAUTONOMY / SELF MAINTENANCE  ============
# =============================================================

BREWAUTONOMY_MODE=passive
BREWASSIST_SELF_REPAIR=enabled
BREWASSIST_SELF_DEBUG=enabled
BREWASSIST_SELF_ANALYSIS=enabled

BREWASSIST_PATCH_ENGINE=enabled
BREWASSIST_PATCH_RISK_THRESHOLD=0.25

# =============================================================
# =================  SANDBOX ENGINE (S4.5)  ===================
# =============================================================

BREWASSIST_SANDBOX_ROOT=./sandbox
BREWASSIST_SANDBOX_ENABLED=true
BREWASSIST_SANDBOX_MIRROR=enabled
BREWASSIST_SANDBOX_APPLY_MODE=manual
BREWASSIST_SANDBOX_DEPTH=3
BREWASSIST_SANDBOX_ALLOW_WRITE=true
BREWASSIST_SANDBOX_ALLOW_READ=true

# =============================================================
# ==================  HRM v3 INTEGRATION  =====================
# =============================================================

HRM_MODEL=hrm-v3
HRM_CHAIN_MODE=strict
HRM_AGENT_ROUTER=enabled

# =============================================================
# =================  RISK ENGINE (S4.6) =======================
# =============================================================

BREWASSIST_RISK_ENGINE=enabled
BREWASSIST_RISK_THRESHOLD=0.4
BREWASSIST_RISK_DYNAMIC_ADJUST=true
BREWASSIST_RISK_LOG=true

# =============================================================
# ===================  IDENTITY ENGINE  =======================
# =============================================================

BREWASSIST_IDENTITY_NAME="BrewAssist"
BREWASSIST_IDENTITY_VERSION=4.6
BREWASSIST_IDENTITY_COLOR=gold
BREWASSIST_IDENTITY_GLOW=intense

# =============================================================
# =====================  LOGGING CONFIG  ======================
# =============================================================

LOG_LEVEL=debug
LOG_PRETTY=true
LOG_SAVE=true
LOG_PATH=./logs/brewassist.log

# =============================================================
# =====================  FEATURE FLAGS  =======================
# =============================================================

FEATURE_GUIDE_UI=enabled
FEATURE_IDENTITY_ENGINE=enabled
FEATURE_DEVOPS_ROUTER=enabled
FEATURE_MULTI_ENGINE_LLM=enabled
FEATURE_SANDBOX=enabled
FEATURE_BREWLAST=enabled
FEATURE_PATCH_ENGINE=enabled
FEATURE_SELF_DEBUG=enabled
FEATURE_SELF_REPAIR=enabled
FEATURE_HELP_GUIDE=enabled
FEATURE_SAAS_PRICING=enabled
FEATURE_UI_POLISH=enabled

# =============================================================
# ====================  FUTURE FLAGS (S5)  ====================
# =============================================================

FUTURE_ENTROPY_RADAR=planned
FUTURE_BREWUNIVERSITY_BRIDGE=planned
FUTURE_VOICE_DRIVE=planned
FUTURE_PLAYER_MODE=planned
